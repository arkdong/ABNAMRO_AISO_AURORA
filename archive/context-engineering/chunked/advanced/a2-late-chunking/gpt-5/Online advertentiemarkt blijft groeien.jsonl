{"id": "Online advertentiemarkt blijft groeien__a2-late-chunking__0013", "text": "Technology, Media & Telecom (TMT) is one of the fastest-growing sectors. Helped by the increasing use of software, algorithms and sensors, this sector is at the heart of the digital renewal of other sectors.", "metadata": {"chunk_id": "Online advertentiemarkt blijft groeien__a2-late-chunking__0013", "source_slug": "Online advertentiemarkt blijft groeien", "source_title": "Online advertising market keeps growing", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "a2-late-chunking", "chunk_index": 13, "n_chunks_total": 17, "status": "approved", "date_ingested": "2026-05-06", "requires_late_chunking": true, "source_doc_offset": 13}}
