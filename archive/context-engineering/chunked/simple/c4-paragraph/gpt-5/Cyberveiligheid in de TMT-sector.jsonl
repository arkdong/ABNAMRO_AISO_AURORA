{"id": "Cyberveiligheid in de TMT-sector__c4-paragraph__0018", "text": "Technology, Media & Telecom (TMT) is one of the fastest-growing sectors. The increasing use of software, algorithms and sensors helps this sector drive digital renewal in other sectors.", "metadata": {"chunk_id": "Cyberveiligheid in de TMT-sector__c4-paragraph__0018", "source_slug": "Cyberveiligheid in de TMT-sector", "source_title": "Cybersecurity in the TMT sector", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 18, "n_chunks_total": 24, "status": "approved", "date_ingested": "2026-05-06"}}
