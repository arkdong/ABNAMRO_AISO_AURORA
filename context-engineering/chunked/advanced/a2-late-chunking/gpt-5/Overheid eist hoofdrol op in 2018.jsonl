{"id": "Overheid eist hoofdrol op in 2018__a2-late-chunking__0002", "text": "Technology, Media and Telecom (TMT) is the sector where the new economy becomes visible first. It is the sector that facilitates the digitalisation of the rest of the economy and benefits from it.", "metadata": {"chunk_id": "Overheid eist hoofdrol op in 2018__a2-late-chunking__0002", "source_slug": "Overheid eist hoofdrol op in 2018", "source_title": "Government claims lead role in 2018", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "a2-late-chunking", "chunk_index": 2, "n_chunks_total": 17, "status": "approved", "date_ingested": "2026-05-06", "requires_late_chunking": true, "source_doc_offset": 2}}
