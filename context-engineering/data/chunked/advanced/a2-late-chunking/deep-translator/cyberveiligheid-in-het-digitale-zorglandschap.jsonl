{"id": "cyberveiligheid-in-het-digitale-zorglandschap__a2-late-chunking__0003", "text": "Primary care is digitizing rapidly: from online patient files and communication via apps to sharing medical data with various parties. This makes strong cybersecurity crucial. Watch this webinar for practical insights to strengthen the digital resilience of your organization. We share practical strategies and a clear plan to improve technology, behavior and processes in the field of cybersecurity in healthcare.", "metadata": {"chunk_id": "cyberveiligheid-in-het-digitale-zorglandschap__a2-late-chunking__0003", "source_slug": "cyberveiligheid-in-het-digitale-zorglandschap", "source_title": "Cybersecurity in the digital healthcare landscape", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/cybersecurity/beveiliging/cyberveiligheid-in-het-digitale-zorglandschap.html", "source_date": "2025-10-15", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "beveiliging", "topic": "cybersecurity", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 3, "n_chunks_total": 12, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 3}}
