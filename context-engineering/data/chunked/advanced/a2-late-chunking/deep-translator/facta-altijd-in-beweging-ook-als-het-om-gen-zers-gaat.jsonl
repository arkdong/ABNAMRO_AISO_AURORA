{"id": "facta-altijd-in-beweging-ook-als-het-om-gen-zers-gaat__a2-late-chunking__0000", "text": "# Facta: always on the move, even when it comes to Gen Zers", "metadata": {"chunk_id": "facta-altijd-in-beweging-ook-als-het-om-gen-zers-gaat__a2-late-chunking__0000", "source_slug": "facta-altijd-in-beweging-ook-als-het-om-gen-zers-gaat", "source_title": "Facta: always on the move, even when it comes to Gen Zers", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/ondernemersverhalen/industrie/facta-altijd-in-beweging-ook-als-het-om-gen-zers-gaat.html", "source_date": "2025-05-22", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "ondernemersverhalen", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 0, "n_chunks_total": 30, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 0}}
