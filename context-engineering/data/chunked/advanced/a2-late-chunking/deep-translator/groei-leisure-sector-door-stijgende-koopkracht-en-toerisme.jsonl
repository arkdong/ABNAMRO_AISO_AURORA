{"id": "groei-leisure-sector-door-stijgende-koopkracht-en-toerisme__a2-late-chunking__0007", "text": "For 2026, the VAT increase on overnight stays from 9 to 21 percent will be higher than the sector. As a result, the competitive position of Dutch accommodations may deteriorate compared to those in Belgium and Germany.", "metadata": {"chunk_id": "groei-leisure-sector-door-stijgende-koopkracht-en-toerisme__a2-late-chunking__0007", "source_slug": "groei-leisure-sector-door-stijgende-koopkracht-en-toerisme", "source_title": "Growth of the leisure sector due to increasing purchasing power and tourism", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/leisure/groei-leisure-sector-door-stijgende-koopkracht-en-toerisme.html", "source_date": "2025-08-14", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 7, "n_chunks_total": 16, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 7}}
