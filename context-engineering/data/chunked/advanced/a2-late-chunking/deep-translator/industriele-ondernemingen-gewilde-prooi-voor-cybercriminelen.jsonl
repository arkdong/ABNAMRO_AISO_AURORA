{"id": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen__a2-late-chunking__0004", "text": "[David Kemps](https://www.abnamro.nl/nl/zakelijk/insights/authors/david-kemps/index.html)", "metadata": {"chunk_id": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen__a2-late-chunking__0004", "source_slug": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen", "source_title": "Industrial companies are popular prey for cybercriminals", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/industrie/industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen.html", "source_date": "2025-06-25", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "industrie", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 4, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 4}}
{"id": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen__a2-late-chunking__0005", "text": "The manufacturing and food industries are vulnerable to cyber attacks due to extensive process automation and many digital links within the chain. Production lines that come to a standstill and stolen IP addresses can have enormous consequences. The pressure within the supply chain, growing digitalization, 'smart' machines, carrying out timely updates and sharing data with parties outside the factory are all risk factors that can attract digital criminals.", "metadata": {"chunk_id": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen__a2-late-chunking__0005", "source_slug": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen", "source_title": "Industrial companies are popular prey for cybercriminals", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/industrie/industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen.html", "source_date": "2025-06-25", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "industrie", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 5, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 5}}
{"id": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen__a2-late-chunking__0006", "text": "Read all the facts and developments in the report 'Industrial companies are popular prey for cyber criminals'.", "metadata": {"chunk_id": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen__a2-late-chunking__0006", "source_slug": "industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen", "source_title": "Industrial companies are popular prey for cybercriminals", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/industrie/industriele-ondernemingen-gewilde-prooi-voor-cybercriminelen.html", "source_date": "2025-06-25", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "industrie", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 6, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 6}}
