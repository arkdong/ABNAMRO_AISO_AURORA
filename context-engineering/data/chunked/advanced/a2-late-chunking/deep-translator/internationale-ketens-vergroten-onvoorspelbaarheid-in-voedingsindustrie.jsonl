{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0001", "text": "[Sector forecast](https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/index.html)", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0001", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 1, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 1}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0002", "text": "[Food](https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/food/index.html)", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0002", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 2, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 2}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0003", "text": "Volume growth will return to the food industry in 2025, driven by demand at home and abroad. Volatility in raw material markets and disruptions in shipping due to US import duties are causing unpredictability in international supply chains that are important to the food industry.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0003", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 3, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 3}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0004", "text": "In this video, sector economist Melanie Murk talks in 2 minutes about the growth expectations in the food sector for 2025 and 2026. See what challenges the food sector faces and what you can do as an entrepreneur.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0004", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 4, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 4}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0005", "text": "[Go to the video](/en/business/insights/sectors-and-trends/sectorprognoses/food/volumegrowth-is-back-in-the-foodindustry.html)", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0005", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 5, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 5}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0006", "text": "With a production value of more than 114 billion euros, the food industry accounts for almost a fifth of the total Dutch industrial production value, according to trade association FNLI. ABN AMRO expects a volume increase of 1 percent for the sector in 2025 and zero growth in 2026.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0006", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 6, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 6}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0007", "text": "The growth forecast for the Dutch economy for 2025 has been lowered to 1.2 percent. Consumer confidence is weak and declining and consumer spending is lower than expected. The labor market remains tight and wage increases will continue in 2025.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0007", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 7, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 7}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0008", "text": "Consumption of food, drinks and tobacco increased in the first quarter. Supermarket data from Circana shows volume growth in food and beverages of 1.1 percent through April compared to the same period in 2024. This volume growth, driven by growth in the unprocessed vegetable and fresh bread categories, is expected to continue this year. The volume in the outdoor channel is also growing slightly, as is export. Price increases are still the order of the day. Until April 2025, the prices of food have increased by 3.5 percent and of non-alcoholic drinks by 8.8 percent. The price increase of alcoholic beverages was limited at 1.8 percent.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0008", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 8, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 8}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0009", "text": "In the recent Economic Survey of the Netherlands (COEN), entrepreneurs in the food industry have a more positive view of turnover and profit expectations in April of this year than a few months earlier. Half of beverage entrepreneurs still cite insufficient demand as a major obstacle.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0009", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 9, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 9}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0010", "text": "The proposed simplification of the Corporate Sustainability Reporting Directive (CSRD) and Corporate Sustainability Due Diligence Directive (CSDDD) will relieve workload for many companies in the sector in the short term. However, sustainability remains an important theme, for example to comply with the Water Framework Directive, which will be enforced from 2027. But sustainability also remains on the agenda because customers and society expect this from producers. In addition, climate change is becoming increasingly tangible in daily business operations. For example, failed harvests lead to more volatility in markets for cocoa, vegetables and coffee, for example. Producers must get a grip on this to safeguard their delivery reliability. Because many raw materials are purchased in dollars, a fluctuating exchange rate also causes unpredictability of costs.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0010", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 10, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 10}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0011", "text": "## Exports to the US are concentrated in a few product groups", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0011", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 11, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 11}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0012", "text": "Every year, the Dutch beverage and food industry exports more than 2.3 billion euros to the United States (US). This amounts to approximately 3 percent of total exports. The Netherlands mainly exports alcoholic beverages, fish, crustaceans & molluscs, vegetables & fruit, cheese and chocolate to the US. Earlier this year, ABN AMRO made an analysis of import duties. This shows that exports to the US could fall by 23 percent with a tariff of 10 percent. Individual companies with a lot of exports to the US and less ability to ship products to other markets could be hit hard. Food companies with long-term relationships say they can share the pain among themselves, traders are more likely to opt to stop trading. Some of the companies are currently protected by contractual agreements in which their selling prices are fixed.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0012", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 12, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 12}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0013", "text": "[Read also: Food exports to the US halve due to Trump import tariff](/nl/zakelijk/insights/sectoren-en-trends/food/export-food-to-us-halveert-due-import Tariff-trump.html)", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0013", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 13, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 13}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0014", "text": "The European Union (EU) has announced that previously suspended countermeasures in response to 2018 US import tariffs will be reinstated as part of a possible counter-reaction. This concerns strategically chosen products, including corn, rice, cranberries and cranberry juice, whiskey (bourbon), orange juice and dried beans. In 2024, approximately 2.1 billion worth of food and drinks from the US crossed the Dutch border. Vegetables, fruit and nuts and alcoholic beverages in particular represent a high value for which possible countermeasures apply.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0014", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 14, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 14}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0015", "text": "About 8 percent of imported beef from the US remains free of import tariffs for the time being. Beef imports are made under strict conditions within a fixed quota for which no tariffs apply. Companies in the US are struggling to fully utilize this quota because the EU has strict regulations, including the ban on growth hormones and the European deforestation regulation EUDR. In anticipation of possible countermeasures, some parties are cautious about placing large orders, while other parties are building up large stocks of non-perishable products in particular.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0015", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 15, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 15}}
{"id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0016", "text": "Read all the facts and developments in the report 'Dutch sectors highly dependent on the United States'.", "metadata": {"chunk_id": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie__a2-late-chunking__0016", "source_slug": "internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie", "source_title": "International chains increase unpredictability in the food industry", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/sectorprognoses/food/internationale-ketens-vergroten-onvoorspelbaarheid-in-voedingsindustrie.html", "source_date": "2025-06-20", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "sectorprognoses", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 16, "n_chunks_total": 28, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 16}}
