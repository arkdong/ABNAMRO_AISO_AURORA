{"id": "kosten-in-land-en-tuinbouw-stabiliseren__a2-late-chunking__0017", "text": "The agricultural sector in the Netherlands is characterized by high productivity and quality. Many countries and organizations therefore see the Netherlands as an agricultural guide country. With an export of more than EUR 100 billion, Dutch agriculture and horticulture makes a strong contribution to our economy.", "metadata": {"chunk_id": "kosten-in-land-en-tuinbouw-stabiliseren__a2-late-chunking__0017", "source_slug": "kosten-in-land-en-tuinbouw-stabiliseren", "source_title": "Stabilize costs in agriculture and horticulture", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/stand-van-sectoren/agrarisch/kosten-in-land-en-tuinbouw-stabiliseren.html", "source_date": "2025-09-12", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "stand van sectoren", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 17, "n_chunks_total": 30, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 17}}
