{"id": "zorgsector-innoveert-ook-zonder-kabinet__a2-late-chunking__0000", "text": "# Healthcare sector also innovates without a cabinet", "metadata": {"chunk_id": "zorgsector-innoveert-ook-zonder-kabinet__a2-late-chunking__0000", "source_slug": "zorgsector-innoveert-ook-zonder-kabinet", "source_title": "The healthcare sector also innovates without a cabinet", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/healthcare/zorgsector-innoveert-ook-zonder-kabinet.html", "source_date": "2025-06-03", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "healthcare", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "a2-late-chunking", "chunk_index": 0, "n_chunks_total": 27, "status": "approved", "date_ingested": "2026-04-30", "requires_late_chunking": true, "source_doc_offset": 0}}
