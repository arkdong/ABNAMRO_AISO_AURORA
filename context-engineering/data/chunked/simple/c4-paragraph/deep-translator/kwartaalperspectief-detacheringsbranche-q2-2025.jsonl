{"id": "kwartaalperspectief-detacheringsbranche-q2-2025__c4-paragraph__0003", "text": "[Han Mesters](https://www.abnamro.nl/nl/zakelijk/insights/authors/han-mesters/index.html)", "metadata": {"chunk_id": "kwartaalperspectief-detacheringsbranche-q2-2025__c4-paragraph__0003", "source_slug": "kwartaalperspectief-detacheringsbranche-q2-2025", "source_title": "Quarterly perspective on the secondment industry Q2 2025", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/alle-sectoren/kwartaalperspectief-detacheringsbranche-q2-2025.html", "source_date": "2025-08-13", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "alle sectoren", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "c4-paragraph", "chunk_index": 3, "n_chunks_total": 39, "status": "approved", "date_ingested": "2026-04-30"}}
{"id": "kwartaalperspectief-detacheringsbranche-q2-2025__c4-paragraph__0004", "text": "Secondment workers continue to shrink. The turnover of the 59 secondments consulted within the VvDN fell by 8.2 percent in the second quarter of 2025, compared to the same period in 2024. Ten of the eleven reported end markets show a contraction in turnover compared to the second quarter of 2024. In the second quarter of 2025, there was also a significant contraction in total self-employed turnover, by 24.89 percent. year-on-year.", "metadata": {"chunk_id": "kwartaalperspectief-detacheringsbranche-q2-2025__c4-paragraph__0004", "source_slug": "kwartaalperspectief-detacheringsbranche-q2-2025", "source_title": "Quarterly perspective on the secondment industry Q2 2025", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/alle-sectoren/kwartaalperspectief-detacheringsbranche-q2-2025.html", "source_date": "2025-08-13", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "alle sectoren", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "c4-paragraph", "chunk_index": 4, "n_chunks_total": 39, "status": "approved", "date_ingested": "2026-04-30"}}
{"id": "kwartaalperspectief-detacheringsbranche-q2-2025__c4-paragraph__0005", "text": "Read all the facts and developments in the report 'Quarterly Perspective Secondment Industry Q2 2025'.", "metadata": {"chunk_id": "kwartaalperspectief-detacheringsbranche-q2-2025__c4-paragraph__0005", "source_slug": "kwartaalperspectief-detacheringsbranche-q2-2025", "source_title": "Quarterly perspective on the secondment industry Q2 2025", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/alle-sectoren/kwartaalperspectief-detacheringsbranche-q2-2025.html", "source_date": "2025-08-13", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "alle sectoren", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "c4-paragraph", "chunk_index": 5, "n_chunks_total": 39, "status": "approved", "date_ingested": "2026-04-30"}}
