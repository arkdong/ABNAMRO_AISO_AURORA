{"id": "nederlandse-glasgroentesector-de-kas-als-kracht__c4-paragraph__0018", "text": "The agricultural sector in the Netherlands is characterized by high productivity and quality. Many countries and organizations therefore see the Netherlands as an agricultural guide country. With an export of more than EUR 100 billion, Dutch agriculture and horticulture makes a strong contribution to our economy.", "metadata": {"chunk_id": "nederlandse-glasgroentesector-de-kas-als-kracht__c4-paragraph__0018", "source_slug": "nederlandse-glasgroentesector-de-kas-als-kracht", "source_title": "Dutch greenhouse vegetable sector: The greenhouse as a force", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/agrarisch/nederlandse-glasgroentesector-de-kas-als-kracht.html", "source_date": "2025-07-31", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "agrarisch", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "c4-paragraph", "chunk_index": 18, "n_chunks_total": 27, "status": "approved", "date_ingested": "2026-04-30"}}
