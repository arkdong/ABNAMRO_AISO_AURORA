{"id": "samenwerking-pure-noodzaak-om-logistieke-positie-uit-te-bouwen__c4-paragraph__0000", "text": "# Collaboration is a pure necessity to expand our logistics position", "metadata": {"chunk_id": "samenwerking-pure-noodzaak-om-logistieke-positie-uit-te-bouwen__c4-paragraph__0000", "source_slug": "samenwerking-pure-noodzaak-om-logistieke-positie-uit-te-bouwen", "source_title": "Collaboration is a pure necessity to expand our logistics position", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/logistiek/samenwerking-pure-noodzaak-om-logistieke-positie-uit-te-bouwen.html", "source_date": "2025-10-16", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "logistiek", "topic": "sectoren en trends", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "c4-paragraph", "chunk_index": 0, "n_chunks_total": 29, "status": "approved", "date_ingested": "2026-04-30"}}
