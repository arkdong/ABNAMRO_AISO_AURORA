{"id": "versterk-inkoopvoorwaarden-met-nis2-clausules__c4-paragraph__0000", "text": "# Strengthen purchasing conditions with NIS2 clauses", "metadata": {"chunk_id": "versterk-inkoopvoorwaarden-met-nis2-clausules__c4-paragraph__0000", "source_slug": "versterk-inkoopvoorwaarden-met-nis2-clausules", "source_title": "Strengthen purchasing conditions with NIS2 clauses", "source_url": "https://www.abnamro.nl/nl/zakelijk/insights/cybersecurity/beveiliging/versterk-inkoopvoorwaarden-met-nis2-clausules.html", "source_date": "2025-10-06", "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": "beveiliging", "topic": "cybersecurity", "language_original": "nl", "language_embedded": "en", "translation_method": "deep-translator", "translated_with": "deep-translator", "chunker": "c4-paragraph", "chunk_index": 0, "n_chunks_total": 12, "status": "approved", "date_ingested": "2026-04-30"}}
