{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0003", "text": "[Technology, Media & Telecom](https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/technologie/index.html)", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0003", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 3, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0004", "text": "[Julia Krauwer](https://www.abnamro.nl/nl/zakelijk/insights/auteurs/julia-krauwer/index.html)", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0004", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 4, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0005", "text": "[Mario Bersem](https://www.abnamro.nl/nl/zakelijk/insights/auteurs/mario-bersem/index.html)", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0005", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 5, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0006", "text": "Changing social standards are putting several principles of the online advertising market under pressure. Full transparency and control over the use of personal data are becoming the new standard. Contextual advertising will gain ground.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0006", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 6, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0007", "text": "Google knows someone’s interests based on their search behaviour. Social platform Instagram has insight into users through likes, posts and followed accounts. These data allow targeted adverts.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0007", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 7, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0008", "text": "Most other websites, unlike such ‘walled gardens’, cannot collect so many insights about their users on their own. That is why personalised adverts at smaller publishers often rely on third-party data, including browsing behaviour on previously visited websites. The use of such tracking data will soon become harder.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0008", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 8, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0009", "text": "Your browser does not support HTML video. Here is a [link to download the video](https://assets.abnamro.com/api/public/content/de-toekomst-van-online-gepersonaliseerd-adverteren-original.mp4)", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0009", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 9, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0010", "text": "](https://assets.abnamro.com/api/public/content/de-toekomst-van-online-gepersonaliseerd-adverteren-thumbnail.jpg)](https://assets.abnamro.com/api/public/content/de-toekomst-van-online-gepersonaliseerd-adverteren-720p.mp4)", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0010", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 10, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0011", "text": "For many publishers and advertisers, the big platform companies will continue to play an important role. The reach and amount of available visitor data at small publishers are not enough to interest advertisers one-to-one. Conversely, small advertisers want a simple way to reach their target group online. So both parties will continue to lean on platforms that bring supply and demand for advertising space together. Google is the market leader here.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0011", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 11, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0012", "text": "Besides the power of big technology companies, the consumer’s will also determines where the online advertising market will go. Their privacy awareness will likely strengthen in the coming years through stricter enforcement of the European privacy law GDPR and the requirements of the Digital Services Act. The latter requires clear communication about data use for online adverts and makes it easier to say “no” to tracking. Both requirements put power — at least in part — back in the hands of the internet user.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0012", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 12, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0013", "text": "Also read the report ‘[Privacy protection puts online advertising at a turning point](https://www.abnamro.nl/nl/zakelijk/insights/sectoren-en-trends/technologie/bescherming-privacy-zet-online-adverteren-op-keerpunt.html)’, which explains the research results in detail.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0013", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 13, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0014", "text": "On many stages and platforms, our experts and representatives talk with entrepreneurs and others about current topics. They discuss sustainable business, the circular economy, real estate and social impact. Follow the webinars, podcasts and interviews.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0014", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 14, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0015", "text": "[Watch the videos or listen to the podcasts](https://www.abnamro.nl/nl/zakelijk/insights/in-gesprek/index.html)", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0015", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 15, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0016", "text": "Technology, Media & Telecom (TMT) is one of the fastest-growing sectors. With growing use of software, algorithms and sensors, this sector underpins the digital renewal of other sectors.", "metadata": {"chunk_id": "Online-advertentiemarkt evolueert onder maatschappelijke druk__c4-paragraph__0016", "source_slug": "Online-advertentiemarkt evolueert onder maatschappelijke druk", "source_title": "Online advertising market evolves under social pressure", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 16, "n_chunks_total": 23, "status": "approved", "date_ingested": "2026-05-06"}}
