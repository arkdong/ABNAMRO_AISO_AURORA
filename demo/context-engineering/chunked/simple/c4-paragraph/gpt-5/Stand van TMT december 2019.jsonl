{"id": "Stand van TMT december 2019__c4-paragraph__0002", "text": "![State of TMT December 2019](https://www.abnamro.nl/nl/media/stand%20van%20tmt_dec19_538_tcm16-65994.jpg)", "metadata": {"chunk_id": "Stand van TMT december 2019__c4-paragraph__0002", "source_slug": "Stand van TMT december 2019", "source_title": "State of TMT December 2019", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 2, "n_chunks_total": 14, "status": "approved", "date_ingested": "2026-05-06"}}
{"id": "Stand van TMT december 2019__c4-paragraph__0003", "text": "Growth in the Dutch economy is slowing and the economic indicators have worsened. The TMT sector is affected, but continues to perform relatively well.", "metadata": {"chunk_id": "Stand van TMT december 2019__c4-paragraph__0003", "source_slug": "Stand van TMT december 2019", "source_title": "State of TMT December 2019", "source_url": null, "source_date": null, "doc_type": "article", "channel": "website", "content_type": "insight_article", "sector": null, "topic": null, "language_original": null, "language_embedded": "en", "translation_method": "gpt-5", "translated_with": null, "chunker": "c4-paragraph", "chunk_index": 3, "n_chunks_total": 14, "status": "approved", "date_ingested": "2026-05-06"}}
