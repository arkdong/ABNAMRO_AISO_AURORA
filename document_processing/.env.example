# Dedicated key for the translation pipeline.
# Recommended: create a separate OpenAI API key labelled "AURORA-translation"
# so its spend is tracked under a distinct line item in your OpenAI dashboard.
# The CLI loads this from .env at the project root automatically.
OPENAI_API_KEY_TRANSLATION=

# Fallback. If OPENAI_API_KEY_TRANSLATION is unset, the translator falls back
# to this key. Keep this one for the rest of the AURORA project (task_definition,
# rag, etc.) and use the dedicated key above only for translation runs.
OPENAI_API_KEY=
